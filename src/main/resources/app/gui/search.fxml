<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.TextFlow?>

<SplitPane dividerPositions="0.35"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="app.gui.SearchController"
           styleClass="root-split"
           prefWidth="1280" prefHeight="720">

    <BorderPane styleClass="left-panel">
        <top>
            <VBox spacing="0" styleClass="controls-area">

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="title-bar">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <VBox spacing="1">
                        <Label text="Search Engine" styleClass="app-title"/>
                        <Label text="local file index · iteration 1" styleClass="app-subtitle"/>
                    </VBox>
                </HBox>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                    <TextField fx:id="pathField" promptText="Directory path..."
                               HBox.hgrow="ALWAYS" styleClass="compact-field"/>
                    <Button text="Browse" onAction="#onBrowse" styleClass="btn-flat"/>
                    <Button text="Index"  onAction="#onIndex"  styleClass="btn-accent"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="16" bottom="6" left="16"/></padding>
                    <Label fx:id="statusLabel" text="Ready" styleClass="status-text"/>
                </HBox>

                <ProgressBar fx:id="progressBar" maxWidth="Infinity"
                             visible="false" managed="false"
                             prefHeight="3" styleClass="slim-progress"/>

                <HBox fx:id="reportBox" visible="false" managed="false"
                      styleClass="report-strip" spacing="0" alignment="CENTER">
                    <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
                    <Label fx:id="reportIndexed" text="0" styleClass="rpt-val"/>
                    <Label text=" indexed" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportSkipped" text="0" styleClass="rpt-val"/>
                    <Label text=" skipped" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportDirs" text="0" styleClass="rpt-val"/>
                    <Label text=" dirs" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportErrors" text="0" styleClass="rpt-val"/>
                    <Label text=" errors" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportTime" text="—" styleClass="rpt-val"/>
                </HBox>

                <Separator styleClass="thin-sep"/>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <padding><Insets top="10" right="16" bottom="6" left="16"/></padding>
                    <TextField fx:id="searchField" promptText="Search... (or keyword ext:java)"
                               onAction="#onSearch" HBox.hgrow="ALWAYS"
                               styleClass="search-field"/>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="16" bottom="8" left="16"/></padding>
                    <Label fx:id="resultCountLabel" text="" styleClass="result-count"/>
                </HBox>

            </VBox>
        </top>

        <center>
            <ListView fx:id="resultsList" styleClass="results-list"/>
        </center>
    </BorderPane>

    <BorderPane styleClass="right-panel">
        <top>
            <VBox spacing="0">
                <HBox styleClass="file-bar" alignment="CENTER_LEFT" spacing="10">
                    <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="previewFileLabel" text="No file selected"
                               styleClass="file-title"/>
                        <Label fx:id="filePathLabel" text="" styleClass="file-subtitle"/>
                    </VBox>
                    <Label fx:id="fileExtLabel" text="" styleClass="ext-pill"/>
                </HBox>
                <Separator styleClass="thin-sep"/>
            </VBox>
        </top>

        <center>
            <TabPane fx:id="tabPane" styleClass="preview-tabs"
                     tabClosingPolicy="UNAVAILABLE"
                     maxHeight="Infinity" maxWidth="Infinity">

                <Tab text="Preview">
                    <VBox VBox.vgrow="ALWAYS">
                        <ScrollPane fitToWidth="true" fitToHeight="false"
                                    VBox.vgrow="ALWAYS"
                                    styleClass="code-scroll">
                            <TextFlow fx:id="previewFlow" styleClass="code-flow">
                                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                            </TextFlow>
                        </ScrollPane>
                    </VBox>
                </Tab>

                <Tab text="Full File">
                    <VBox spacing="0">
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                    styleClass="code-scroll">
                            <TextFlow fx:id="fullFileFlow" styleClass="code-flow">
                                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                            </TextFlow>
                        </ScrollPane>
                    </VBox>
                </Tab>

            </TabPane>
        </center>
    </BorderPane>

</SplitPane>
