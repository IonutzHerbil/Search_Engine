<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.TextFlow?>

<SplitPane dividerPositions="0.5"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="app.gui.SearchController"
           styleClass="root-split"
           prefWidth="1280" prefHeight="720">

    <BorderPane styleClass="left-panel">
        <top>
            <VBox spacing="0" styleClass="controls-area">

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="title-bar">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <VBox spacing="1">
                        <Label text="Search Engine" styleClass="app-title"/>
                        <Label text="local file index · iteration 1" styleClass="app-subtitle"/>
                    </VBox>
                </HBox>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                    <TextField fx:id="pathField" promptText="Directory path..."
                               HBox.hgrow="ALWAYS" styleClass="compact-field"/>
                    <Button text="Browse" onAction="#onBrowse" styleClass="btn-flat"/>
                    <Button text="Index"  onAction="#onIndex"  styleClass="btn-accent"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="16" bottom="6" left="16"/></padding>
                    <Label text="Report format:" styleClass="status-text"/>
                    <ChoiceBox fx:id="reportFormatChoice" styleClass="compact-field"/>
                    <Button text="Export Report" fx:id="exportReportButton"
                            onAction="#onExportReport" styleClass="btn-flat"
                            disable="true"/>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <padding><Insets top="4" right="16" bottom="0" left="16"/></padding>
                    <Button text="▸ Configure ignore rules" onAction="#onToggleSettings"
                            fx:id="settingsToggle" styleClass="btn-flat"/>
                </HBox>

                <VBox fx:id="settingsBox" visible="false" managed="false" spacing="6">
                    <padding><Insets top="6" right="16" bottom="10" left="16"/></padding>

                    <Label text="SKIP THESE EXTENSIONS"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4c566a;"/>
                    <Label text="Comma separated — e.g. exe, dll, class"
                           style="-fx-font-size: 12px; -fx-text-fill: #4c566a;"/>
                    <TextArea fx:id="ignoredExtsField"
                              prefRowCount="4"
                              styleClass="compact-field"
                              style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 11px;"/>

                    <Label text="SKIP THESE DIRECTORIES"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4c566a;
                  -fx-padding: 4 0 0 0;"/>
                    <Label text="One name per line — e.g. node_modules, .git"
                           style="-fx-font-size: 12px; -fx-text-fill: #4c566a;"/>
                    <TextArea fx:id="ignoredDirsField"
                              prefRowCount="4"
                              styleClass="compact-field"
                              style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 11px;"/>

                    <Label text="Prefix with . to match hidden directories (e.g. .git)"
                           style="-fx-font-size: 9px; -fx-text-fill: #4c566a; -fx-font-style: italic;"/>
                </VBox>

                <HBox alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="16" bottom="6" left="16"/></padding>
                    <Label fx:id="statusLabel" text="Ready" styleClass="status-text"/>
                </HBox>

                <ProgressBar fx:id="progressBar" maxWidth="Infinity"
                             visible="false" managed="false"
                             prefHeight="3" styleClass="slim-progress"/>

                <HBox fx:id="reportBox" visible="false" managed="false"
                      styleClass="report-strip" spacing="0" alignment="CENTER">
                    <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
                    <Label fx:id="reportTotal" text="0" styleClass="rpt-val"/>
                    <Label text=" total" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportNew" text="0" styleClass="rpt-val"/>
                    <Label text=" new" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportUpdated" text="0" styleClass="rpt-val"/>
                    <Label text=" updated" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportUpToDate" text="0" styleClass="rpt-val"/>
                    <Label text=" up to date" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportFiltered" text="0" styleClass="rpt-val"/>
                    <Label text=" filtered" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportErrors" text="0" styleClass="rpt-val"/>
                    <Label text=" errors" styleClass="rpt-lbl"/>
                    <Label text="  ·  " styleClass="rpt-sep"/>
                    <Label fx:id="reportTime" text="—" styleClass="rpt-val"/>
                </HBox>

                <Separator styleClass="thin-sep"/>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <padding><Insets top="10" right="16" bottom="6" left="16"/></padding>
                    <TextField fx:id="searchField" promptText="keyword  ext:java  path:src  name:Main  content:import"
                               onAction="#onSearch" HBox.hgrow="ALWAYS"
                               styleClass="search-field"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="16" bottom="6" left="16"/></padding>
                    <ComboBox fx:id="extFilter" promptText="ext" editable="true"
                              prefWidth="100" styleClass="compact-field"/>
                    <TextField fx:id="dirFilter" promptText="dir filter..."
                               HBox.hgrow="ALWAYS" styleClass="compact-field"/>
                    <ChoiceBox fx:id="sortChoice" styleClass="compact-field"/>
                    <Button text="Clear" onAction="#onClearFilters" styleClass="btn-flat"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <padding><Insets top="0" right="16" bottom="8" left="16"/></padding>
                    <Label fx:id="resultCountLabel" text="" styleClass="result-count"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="loadMoreButton" text="Load more"
                            onAction="#onLoadMore" styleClass="btn-flat"
                            visible="false" managed="false"/>
                </HBox>

            </VBox>
        </top>

        <center>
            <ListView fx:id="resultsList" styleClass="results-list"/>
        </center>
    </BorderPane>

    <BorderPane styleClass="right-panel">
        <top>
            <VBox spacing="0">
                <HBox styleClass="file-bar" alignment="CENTER_LEFT" spacing="10">
                    <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="previewFileLabel" text="No file selected"
                               styleClass="file-title"/>
                        <Label fx:id="filePathLabel" text="" styleClass="file-subtitle"/>
                    </VBox>
                    <Label fx:id="fileExtLabel" text="" styleClass="ext-pill"/>
                </HBox>
                <Separator styleClass="thin-sep"/>
            </VBox>
        </top>

        <center>
            <TabPane fx:id="tabPane" styleClass="preview-tabs"
                     tabClosingPolicy="UNAVAILABLE"
                     maxHeight="Infinity" maxWidth="Infinity">

                <Tab text="Preview">
                    <VBox VBox.vgrow="ALWAYS">
                        <ScrollPane fitToWidth="true" fitToHeight="false"
                                    VBox.vgrow="ALWAYS"
                                    styleClass="code-scroll">
                            <TextFlow fx:id="previewFlow" styleClass="code-flow">
                                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                            </TextFlow>
                        </ScrollPane>
                    </VBox>
                </Tab>

                <Tab text="Full File">
                    <VBox spacing="0">
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                    styleClass="code-scroll">
                            <TextFlow fx:id="fullFileFlow" styleClass="code-flow">
                                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                            </TextFlow>
                        </ScrollPane>
                    </VBox>
                </Tab>

            </TabPane>
        </center>
    </BorderPane>

</SplitPane>
